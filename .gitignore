# NIO Racing Plus - Git Ignore

# Python cache
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Assets directory (large binary files, download separately)
Assets/

# UE5 generated files
NomiRacingPlus/Binaries/
NomiRacingPlus/Intermediate/
NomiRacingPlus/Saved/
NomiRacingPlus/DerivedDataCache/
NomiRacingPlus/.vs/
NomiRacingPlus/*.sln
NomiRacingPlus/*.suo

# Content binary files (textures, audio, meshes)
# These are generated/downloaded assets, not source code
NomiRacingPlus/Content/Audio/Motor/*.wav
NomiRacingPlus/Content/Audio/SFX/*.wav
NomiRacingPlus/Content/Audio/UI/*.wav
NomiRacingPlus/Content/Audio/Music/*.wav
NomiRacingPlus/Content/Textures/
NomiRacingPlus/Content/Materials/*.uasset
NomiRacingPlus/Content/Vehicles/*/Meshes/*.fbx
NomiRacingPlus/Content/Vehicles/*/Textures/*.png

# Keep JSON configuration files
!NomiRacingPlus/Content/**/*.json

# Keep audio generation scripts
!NomiRacingPlus/Assets/Audio/*.py

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
*.pdb
*.ilk
*.obj
*.log

# Temporary files
*.tmp
*.bak
*.cache

# Source backup directory
NomiRacingPlus/Source_backup/
