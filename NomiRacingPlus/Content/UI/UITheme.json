{
    "theme": {
        "name": "NIO Racing Plus Theme",
        "version": "2.0.0",
        "description": "Comprehensive UI theme for NIO Racing Plus with brand colors, typography, animations, and responsive layouts",
        "colors": {
            "primary": {
                "nio_blue": "#00A1E0",
                "nio_blue_rgb": [0, 161, 224],
                "nio_blue_linear": [0.0, 0.631, 0.878],
                "nio_cyan": "#00D4FF",
                "nio_cyan_rgb": [0, 212, 255],
                "nio_cyan_linear": [0.0, 0.831, 1.0],
                "nio_blue_dark": "#0078B4",
                "nio_blue_dark_rgb": [0, 120, 180],
                "nio_blue_light": "#4DC9F6",
                "nio_blue_light_rgb": [77, 201, 246],
                "nio_blue_pale": "#B3E5FC",
                "nio_blue_pale_rgb": [179, 229, 252]
            },
            "gradients": {
                "blue_to_cyan": {
                    "start": "#0078B4",
                    "end": "#00D4FF",
                    "angle": 90,
                    "css": "linear-gradient(90deg, #0078B4, #00D4FF)"
                },
                "dark_to_blue": {
                    "start": "#0A0E1A",
                    "end": "#00A1E0",
                    "angle": 180,
                    "css": "linear-gradient(180deg, #0A0E1A, #00A1E0)"
                },
                "radial_glow": {
                    "center": "#00D4FF",
                    "edge": "transparent",
                    "css": "radial-gradient(circle, rgba(0, 212, 255, 0.3), transparent)"
                },
                "speed_gradient": {
                    "low": "#7FFF00",
                    "mid": "#FFB800",
                    "high": "#FF2244",
                    "css": "linear-gradient(90deg, #7FFF00, #FFB800, #FF2244)"
                }
            },
            "background": {
                "main": "#0A0E1A",
                "main_rgb": [10, 14, 26],
                "panel": "#0F1629",
                "panel_rgb": [15, 22, 41],
                "card": "#141B2D",
                "card_rgb": [20, 27, 45],
                "elevated": "#1A2340",
                "elevated_rgb": [26, 35, 64],
                "overlay": "rgba(10, 14, 26, 0.85)",
                "overlay_light": "rgba(10, 14, 26, 0.6)",
                "overlay_heavy": "rgba(10, 14, 26, 0.95)",
                "scrim": "rgba(0, 0, 0, 0.5)"
            },
            "text": {
                "primary": "#F0F0F0",
                "primary_rgb": [240, 240, 240],
                "secondary": "#8899AA",
                "secondary_rgb": [136, 153, 170],
                "muted": "#556677",
                "muted_rgb": [85, 102, 119],
                "accent": "#00D4FF",
                "inverse": "#0A0E1A",
                "on_primary": "#FFFFFF",
                "on_danger": "#FFFFFF",
                "on_success": "#0A0E1A"
            },
            "status": {
                "success": "#7FFF00",
                "success_rgb": [127, 255, 0],
                "success_bg": "rgba(127, 255, 0, 0.15)",
                "warning": "#FFB800",
                "warning_rgb": [255, 184, 0],
                "warning_bg": "rgba(255, 184, 0, 0.15)",
                "danger": "#FF2244",
                "danger_rgb": [255, 34, 68],
                "danger_bg": "rgba(255, 34, 68, 0.15)",
                "info": "#00A1E0",
                "info_rgb": [0, 161, 224],
                "info_bg": "rgba(0, 161, 224, 0.15)"
            },
            "vehicle": {
                "ep9": "#FF4444",
                "ep9_name": "NIO Red",
                "et7": "#4488FF",
                "et7_name": "NIO Electric Blue",
                "es7": "#44CC88",
                "es7_name": "NIO Forest",
                "et5": "#FFB844",
                "et5_name": "NIO Amber"
            },
            "race": {
                "first_place": "#FFD700",
                "first_place_name": "Gold",
                "second_place": "#C0C0C0",
                "second_place_name": "Silver",
                "third_place": "#CD7F32",
                "third_place_name": "Bronze",
                "player": "#00D4FF",
                "ai": "#FF6B6B",
                "player_trail": "rgba(0, 212, 255, 0.4)",
                "ai_trail": "rgba(255, 107, 107, 0.3)"
            },
            "accessibility": {
                "colorblind_safe": {
                    "success": "#0077BB",
                    "success_name": "Blue (replaces green)",
                    "danger": "#EE7733",
                    "danger_name": "Orange (replaces red)",
                    "warning": "#CCBB44",
                    "warning_name": "Yellow-green",
                    "info": "#33BBEE",
                    "info_name": "Cyan"
                },
                "high_contrast": {
                    "text_primary": "#FFFFFF",
                    "text_secondary": "#CCCCCC",
                    "background": "#000000",
                    "border": "#FFFFFF",
                    "accent": "#00D4FF"
                }
            },
            "opacity": {
                "transparent": 0.0,
                "hint": 0.1,
                "disabled": 0.3,
                "overlay": 0.5,
                "medium": 0.7,
                "high": 0.85,
                "opaque": 1.0
            }
        },
        "typography": {
            "fonts": {
                "primary": {
                    "family": "Rajdhani",
                    "source": "Google Fonts",
                    "url": "https://fonts.google.com/specimen/Rajdhani",
                    "weights": [300, 400, 500, 600, 700],
                    "style": "Modern, geometric, tech-forward",
                    "use_for": "Body text, UI labels, general content"
                },
                "secondary": {
                    "family": "Orbitron",
                    "source": "Google Fonts",
                    "url": "https://fonts.google.com/specimen/Orbitron",
                    "weights": [400, 500, 600, 700, 800, 900],
                    "style": "Futuristic, space-age, display",
                    "use_for": "Speed numbers, headings, emphasis"
                },
                "mono": {
                    "family": "Exo 2",
                    "source": "Google Fonts",
                    "url": "https://fonts.google.com/specimen/Exo+2",
                    "weights": [100, 200, 300, 400, 500, 600, 700, 800, 900],
                    "style": "Technical, clean, versatile",
                    "use_for": "Timers, data readouts, technical info"
                },
                "fallback": {
                    "family": "Roboto",
                    "use_for": "Fallback when primary fonts unavailable"
                }
            },
            "scale": {
                "h1": {
                    "size_px": 96,
                    "font": "secondary",
                    "weight": 700,
                    "line_height": 1.1,
                    "letter_spacing": 2.0,
                    "use_for": "Speed display, countdown numbers"
                },
                "h2": {
                    "size_px": 48,
                    "font": "secondary",
                    "weight": 600,
                    "line_height": 1.2,
                    "letter_spacing": 1.5,
                    "use_for": "Position display, section headers"
                },
                "h3": {
                    "size_px": 36,
                    "font": "primary",
                    "weight": 600,
                    "line_height": 1.3,
                    "letter_spacing": 1.0,
                    "use_for": "Track name, lap counter"
                },
                "h4": {
                    "size_px": 24,
                    "font": "primary",
                    "weight": 500,
                    "line_height": 1.4,
                    "letter_spacing": 0.5,
                    "use_for": "Subheadings, menu items"
                },
                "body": {
                    "size_px": 18,
                    "font": "primary",
                    "weight": 400,
                    "line_height": 1.5,
                    "letter_spacing": 0.0,
                    "use_for": "NOMI comments, descriptions"
                },
                "body_small": {
                    "size_px": 16,
                    "font": "primary",
                    "weight": 400,
                    "line_height": 1.5,
                    "letter_spacing": 0.0,
                    "use_for": "Secondary body text"
                },
                "small": {
                    "size_px": 14,
                    "font": "primary",
                    "weight": 400,
                    "line_height": 1.4,
                    "letter_spacing": 0.25,
                    "use_for": "Labels, helper text"
                },
                "caption": {
                    "size_px": 12,
                    "font": "primary",
                    "weight": 300,
                    "line_height": 1.4,
                    "letter_spacing": 0.5,
                    "use_for": "Captions, fine print"
                },
                "overline": {
                    "size_px": 10,
                    "font": "primary",
                    "weight": 500,
                    "line_height": 1.6,
                    "letter_spacing": 1.5,
                    "use_for": "Category labels, badges"
                }
            },
            "timer_display": {
                "font": "mono",
                "size_px": 28,
                "weight": 500,
                "letter_spacing": 1.0,
                "format": "MM:SS.mmm",
                "separator_color": "#8899AA"
            },
            "speed_display": {
                "font": "secondary",
                "size_px": 96,
                "weight": 700,
                "letter_spacing": 2.0,
                "unit_font": "primary",
                "unit_size_px": 24,
                "unit_weight": 400,
                "color_normal": "#00D4FF",
                "color_warning": "#FFB800",
                "color_danger": "#FF2244",
                "speed_thresholds": {
                    "normal_max_kmh": 150,
                    "warning_max_kmh": 250,
                    "danger_above_kmh": 250
                }
            }
        },
        "spacing": {
            "base_unit": 4,
            "scale": {
                "0": 0,
                "1": 4,
                "2": 8,
                "3": 12,
                "4": 16,
                "5": 20,
                "6": 24,
                "7": 28,
                "8": 32,
                "9": 36,
                "10": 40,
                "12": 48,
                "14": 56,
                "16": 64,
                "20": 80,
                "24": 96,
                "32": 128
            },
            "semantic": {
                "xs": 4,
                "sm": 8,
                "md": 16,
                "lg": 24,
                "xl": 32,
                "xxl": 48,
                "xxxl": 64
            },
            "component": {
                "button_padding_h": 24,
                "button_padding_v": 12,
                "input_padding_h": 16,
                "input_padding_v": 10,
                "card_padding": 16,
                "panel_padding": 24,
                "section_gap": 32,
                "page_margin": 48
            }
        },
        "borders": {
            "radius": {
                "none": 0,
                "xs": 2,
                "sm": 4,
                "md": 8,
                "lg": 12,
                "xl": 16,
                "xxl": 24,
                "round": 999,
                "pill": 9999
            },
            "width": {
                "hairline": 0.5,
                "thin": 1,
                "medium": 2,
                "thick": 3,
                "heavy": 4
            },
            "color": {
                "default": "rgba(0, 161, 224, 0.2)",
                "hover": "rgba(0, 212, 255, 0.4)",
                "focus": "#00A1E0",
                "active": "#00D4FF",
                "disabled": "rgba(85, 102, 119, 0.3)",
                "danger": "rgba(255, 34, 68, 0.5)",
                "success": "rgba(127, 255, 0, 0.5)"
            }
        },
        "shadows": {
            "elevation": {
                "none": "none",
                "sm": "0 1px 2px rgba(0, 0, 0, 0.2)",
                "md": "0 2px 4px rgba(0, 0, 0, 0.3)",
                "lg": "0 4px 8px rgba(0, 0, 0, 0.4)",
                "xl": "0 8px 16px rgba(0, 0, 0, 0.5)",
                "xxl": "0 16px 32px rgba(0, 0, 0, 0.6)"
            },
            "glow": {
                "blue_sm": "0 0 4px rgba(0, 161, 224, 0.3)",
                "blue_md": "0 0 10px rgba(0, 161, 224, 0.4)",
                "blue_lg": "0 0 20px rgba(0, 161, 224, 0.5)",
                "blue_xl": "0 0 40px rgba(0, 161, 224, 0.6)",
                "cyan_sm": "0 0 4px rgba(0, 212, 255, 0.3)",
                "cyan_md": "0 0 10px rgba(0, 212, 255, 0.4)",
                "cyan_lg": "0 0 20px rgba(0, 212, 255, 0.5)",
                "danger_sm": "0 0 4px rgba(255, 34, 68, 0.3)",
                "danger_md": "0 0 10px rgba(255, 34, 68, 0.4)",
                "success_sm": "0 0 4px rgba(127, 255, 0, 0.3)",
                "success_md": "0 0 10px rgba(127, 255, 0, 0.4)"
            },
            "inset": {
                "sm": "inset 0 1px 2px rgba(0, 0, 0, 0.3)",
                "md": "inset 0 2px 4px rgba(0, 0, 0, 0.4)"
            }
        },
        "animations": {
            "duration": {
                "instant": 0.05,
                "fast": 0.15,
                "normal": 0.3,
                "slow": 0.5,
                "slower": 0.8,
                "glacial": 1.2
            },
            "delay": {
                "none": 0.0,
                "short": 0.05,
                "medium": 0.1,
                "long": 0.2
            },
            "easing": {
                "linear": {
                    "name": "Linear",
                    "css": "linear",
                    "bezier": [0.0, 0.0, 1.0, 1.0],
                    "use_for": "Progress bars, continuous motion"
                },
                "ease_in": {
                    "name": "Ease In",
                    "css": "ease-in",
                    "bezier": [0.4, 0.0, 1.0, 1.0],
                    "use_for": "Elements entering screen"
                },
                "ease_out": {
                    "name": "Ease Out",
                    "css": "ease-out",
                    "bezier": [0.0, 0.0, 0.2, 1.0],
                    "use_for": "Elements exiting screen, default transitions"
                },
                "ease_in_out": {
                    "name": "Ease In Out",
                    "css": "ease-in-out",
                    "bezier": [0.4, 0.0, 0.2, 1.0],
                    "use_for": "Smooth transitions, state changes"
                },
                "ease_out_back": {
                    "name": "Ease Out Back (Overshoot)",
                    "css": "cubic-bezier(0.34, 1.56, 0.64, 1.0)",
                    "bezier": [0.34, 1.56, 0.64, 1.0],
                    "use_for": "Pop-in effects, attention-grabbing"
                },
                "ease_in_back": {
                    "name": "Ease In Back (Anticipate)",
                    "css": "cubic-bezier(0.6, -0.28, 0.735, 0.045)",
                    "bezier": [0.6, -0.28, 0.735, 0.045],
                    "use_for": "Elements pulling back before action"
                },
                "bounce": {
                    "name": "Bounce",
                    "css": "cubic-bezier(0.68, -0.55, 0.265, 1.55)",
                    "bezier": [0.68, -0.55, 0.265, 1.55],
                    "use_for": "Celebrations, achievement unlocks"
                },
                "spring": {
                    "name": "Spring",
                    "css": "cubic-bezier(0.175, 0.885, 0.32, 1.275)",
                    "bezier": [0.175, 0.885, 0.32, 1.275],
                    "use_for": "Natural-feeling movements"
                },
                "sharp": {
                    "name": "Sharp",
                    "css": "cubic-bezier(0.4, 0.0, 0.6, 1.0)",
                    "bezier": [0.4, 0.0, 0.6, 1.0],
                    "use_for": "Quick emphasis, micro-interactions"
                },
                "smooth": {
                    "name": "Smooth",
                    "css": "cubic-bezier(0.25, 0.1, 0.25, 1.0)",
                    "bezier": [0.25, 0.1, 0.25, 1.0],
                    "use_for": "General smooth motion"
                }
            },
            "keyframes": {
                "fade_in": {
                    "from": { "opacity": 0 },
                    "to": { "opacity": 1 }
                },
                "fade_out": {
                    "from": { "opacity": 1 },
                    "to": { "opacity": 0 }
                },
                "slide_in_left": {
                    "from": { "transform": "translateX(-100%)", "opacity": 0 },
                    "to": { "transform": "translateX(0)", "opacity": 1 }
                },
                "slide_in_right": {
                    "from": { "transform": "translateX(100%)", "opacity": 0 },
                    "to": { "transform": "translateX(0)", "opacity": 1 }
                },
                "slide_in_up": {
                    "from": { "transform": "translateY(20px)", "opacity": 0 },
                    "to": { "transform": "translateY(0)", "opacity": 1 }
                },
                "slide_in_down": {
                    "from": { "transform": "translateY(-20px)", "opacity": 0 },
                    "to": { "transform": "translateY(0)", "opacity": 1 }
                },
                "scale_in": {
                    "from": { "transform": "scale(0.8)", "opacity": 0 },
                    "to": { "transform": "scale(1)", "opacity": 1 }
                },
                "pulse": {
                    "0%": { "opacity": 1 },
                    "50%": { "opacity": 0.5 },
                    "100%": { "opacity": 1 }
                },
                "glow_pulse": {
                    "0%": { "box-shadow": "0 0 5px rgba(0, 161, 224, 0.3)" },
                    "50%": { "box-shadow": "0 0 20px rgba(0, 161, 224, 0.6)" },
                    "100%": { "box-shadow": "0 0 5px rgba(0, 161, 224, 0.3)" }
                },
                "shake": {
                    "0%": { "transform": "translateX(0)" },
                    "25%": { "transform": "translateX(-4px)" },
                    "50%": { "transform": "translateX(4px)" },
                    "75%": { "transform": "translateX(-4px)" },
                    "100%": { "transform": "translateX(0)" }
                },
                "countdown_pop": {
                    "0%": { "transform": "scale(2)", "opacity": 0 },
                    "50%": { "transform": "scale(1.1)", "opacity": 1 },
                    "100%": { "transform": "scale(1)", "opacity": 1 }
                },
                "speed_flash": {
                    "0%": { "color": "#00D4FF" },
                    "50%": { "color": "#FF2244" },
                    "100%": { "color": "#00D4FF" }
                }
            },
            "transitions": {
                "button_hover": {
                    "duration": 0.15,
                    "easing": "ease_out",
                    "properties": ["background", "border-color", "box-shadow"]
                },
                "button_press": {
                    "duration": 0.05,
                    "easing": "linear",
                    "properties": ["transform", "background"]
                },
                "panel_slide": {
                    "duration": 0.3,
                    "easing": "ease_out",
                    "properties": ["transform", "opacity"]
                },
                "nomi_comment": {
                    "duration": 0.3,
                    "easing": "ease_out",
                    "properties": ["opacity", "transform"]
                },
                "nomi_comment_exit": {
                    "duration": 0.3,
                    "easing": "ease_in",
                    "properties": ["opacity"]
                },
                "hud_element_enter": {
                    "duration": 0.4,
                    "easing": "ease_out_back",
                    "properties": ["opacity", "transform"]
                },
                "countdown": {
                    "duration": 0.5,
                    "easing": "bounce",
                    "properties": ["transform", "opacity"]
                },
                "menu_transition": {
                    "duration": 0.3,
                    "easing": "ease_in_out",
                    "properties": ["opacity", "transform"]
                }
            },
            "physics": {
                "spring_stiffness": 300,
                "spring_damping": 20,
                "spring_mass": 1.0
            }
        },
        "components": {
            "button": {
                "normal": {
                    "background": "rgba(0, 161, 224, 0.2)",
                    "border": "2px solid #00A1E0",
                    "border_radius": 8,
                    "text": "#00A1E0",
                    "padding_h": 24,
                    "padding_v": 12,
                    "min_width": 120,
                    "min_height": 44,
                    "font_size": 18,
                    "font_weight": 500
                },
                "hover": {
                    "background": "rgba(0, 161, 224, 0.35)",
                    "border": "2px solid #00D4FF",
                    "text": "#00D4FF",
                    "glow": "0 0 12px rgba(0, 212, 255, 0.3)",
                    "scale": 1.02
                },
                "pressed": {
                    "background": "rgba(0, 161, 224, 0.5)",
                    "border": "2px solid #0078B4",
                    "text": "#FFFFFF",
                    "scale": 0.97
                },
                "disabled": {
                    "background": "rgba(85, 102, 119, 0.2)",
                    "border": "2px solid rgba(85, 102, 119, 0.4)",
                    "text": "#556677",
                    "cursor": "not-allowed"
                },
                "focus": {
                    "border": "2px solid #00D4FF",
                    "glow": "0 0 0 3px rgba(0, 212, 255, 0.2)"
                }
            },
            "button_primary": {
                "normal": {
                    "background": "linear-gradient(135deg, #00A1E0, #0078B4)",
                    "border": "none",
                    "text": "#FFFFFF",
                    "font_weight": 600
                },
                "hover": {
                    "background": "linear-gradient(135deg, #00B4F6, #00A1E0)",
                    "glow": "0 0 20px rgba(0, 161, 224, 0.5)"
                }
            },
            "button_danger": {
                "normal": {
                    "background": "rgba(255, 34, 68, 0.2)",
                    "border": "2px solid #FF2244",
                    "text": "#FF2244"
                },
                "hover": {
                    "background": "rgba(255, 34, 68, 0.35)",
                    "glow": "0 0 12px rgba(255, 34, 68, 0.3)"
                }
            },
            "panel": {
                "background": "rgba(15, 22, 41, 0.9)",
                "border": "1px solid rgba(0, 161, 224, 0.15)",
                "border_radius": 12,
                "padding": 24,
                "backdrop_filter": "blur(10px)",
                "shadow": "0 4px 12px rgba(0, 0, 0, 0.3)"
            },
            "panel_elevated": {
                "background": "rgba(20, 27, 45, 0.95)",
                "border": "1px solid rgba(0, 161, 224, 0.25)",
                "border_radius": 12,
                "padding": 24,
                "shadow": "0 8px 24px rgba(0, 0, 0, 0.4)"
            },
            "card": {
                "background": "rgba(20, 27, 45, 0.8)",
                "border": "1px solid rgba(0, 161, 224, 0.1)",
                "border_radius": 8,
                "padding": 16,
                "hover_border": "1px solid rgba(0, 161, 224, 0.3)",
                "hover_shadow": "0 4px 12px rgba(0, 161, 224, 0.1)"
            },
            "input": {
                "background": "rgba(20, 27, 45, 0.8)",
                "border": "1px solid rgba(0, 161, 224, 0.3)",
                "border_radius": 8,
                "padding_h": 16,
                "padding_v": 10,
                "focus_border": "1px solid #00A1E0",
                "focus_glow": "0 0 0 3px rgba(0, 161, 224, 0.15)",
                "text": "#F0F0F0",
                "placeholder": "#556677",
                "error_border": "1px solid #FF2244",
                "error_glow": "0 0 0 3px rgba(255, 34, 68, 0.15)"
            },
            "progress_bar": {
                "height": 8,
                "background": "rgba(20, 27, 45, 0.8)",
                "fill": "#00A1E0",
                "fill_gradient": "linear-gradient(90deg, #0078B4, #00D4FF)",
                "border_radius": 4,
                "animation": "shimmer"
            },
            "slider": {
                "track_height": 4,
                "track_bg": "rgba(20, 27, 45, 0.8)",
                "fill": "#00A1E0",
                "thumb_size": 20,
                "thumb_bg": "#FFFFFF",
                "thumb_border": "2px solid #00A1E0",
                "thumb_glow": "0 0 8px rgba(0, 161, 224, 0.3)"
            },
            "toggle": {
                "width": 48,
                "height": 24,
                "off_background": "rgba(85, 102, 119, 0.4)",
                "on_background": "#00A1E0",
                "thumb_size": 20,
                "thumb_bg": "#FFFFFF",
                "transition": "0.2s ease-in-out"
            },
            "tooltip": {
                "background": "rgba(15, 22, 41, 0.95)",
                "border": "1px solid rgba(0, 161, 224, 0.3)",
                "border_radius": 6,
                "padding_h": 12,
                "padding_v": 8,
                "text": "#F0F0F0",
                "font_size": 14,
                "shadow": "0 4px 12px rgba(0, 0, 0, 0.4)",
                "arrow_size": 6
